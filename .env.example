# Optional: public site URL for auth email links (defaults to browser origin at runtime)
# NEXT_PUBLIC_APP_URL=https://your-production-domain.com

# Database (Neon pooled connection string)
DATABASE_URL=

# Neon Auth — from Neon Console → Branch → Auth → Configuration
NEON_AUTH_BASE_URL=
# Generate with: openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET=
# Email/password verification is configured in Neon Console (Auth):
# enable Verify at Sign-up and choose Verification code (OTP).
# Optional: set a custom SMTP provider for production email delivery.

# Vercel Blob — auto-injected when Blob store is linked, or from Vercel dashboard
BLOB_READ_WRITE_TOKEN=

# AI document summaries (@icare/document-summary-ai) + organization assistant (optional)
GEMINI_API_KEY=
# Alternative key name supported by Vercel AI SDK
GOOGLE_GENERATIVE_AI_API_KEY=
# Override default model (gemini-2.5-flash-lite)
GEMINI_MODEL=

# Ops alerting — Slack incoming webhook for care share requests (optional)
SLACK_WEBHOOK_URL=

# Slack bot file uploads (optional; requires files:write scope)
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Set to true only for CI/build without real secrets
# SKIP_ENV_VALIDATION=true
