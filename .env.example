# Database (Neon pooled connection string)
DATABASE_URL=

# Neon Auth — from Neon Console → Branch → Auth → Configuration
NEON_AUTH_BASE_URL=
# Generate with: openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET=

# Vercel Blob — auto-injected when Blob store is linked, or from Vercel dashboard
BLOB_READ_WRITE_TOKEN=

# Phase 2 (optional) — Google AI Studio key from https://aistudio.google.com/apikey
# Also accepts GOOGLE_GENERATIVE_AI_API_KEY as an alias
GEMINI_API_KEY=
# Optional model override (default: gemini-2.5-flash-lite for free-tier compatibility)
# GEMINI_MODEL=gemini-2.5-flash-lite

# Ops alerting — Slack incoming webhook for upload portal + care share notifications
SLACK_WEBHOOK_URL=

# Slack bot — posts PDF files to a channel (requires files:write scope; invite bot to channel)
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Set to true only for CI/build without real secrets
# SKIP_ENV_VALIDATION=true
